{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/clusters/bare-metal/config/system-upgrade/app\\.yaml/"],
      "matchStrings": ["channel: https://update\\.k3s\\.io/v1-release/channels/(?<currentValue>v[0-9]+\\.[0-9]+)"],
      "depNameTemplate": "k3s-io/k3s",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<major>[0-9]+)\\.(?<minor>[0-9]+)"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/clusters/bare-metal/config/system-upgrade/app\\.yaml/"],
      "matchStrings": ["https://github\\.com/rancher/system-upgrade-controller/releases/download/(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)/system-upgrade-controller\\.yaml"],
      "depNameTemplate": "rancher/system-upgrade-controller",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/install\\.sh/"],
      "matchStrings": ["kapp-controller/releases/download/(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)/release\\.yml"],
      "depNameTemplate": "carvel-dev/kapp-controller",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/install\\.sh/"],
      "matchStrings": ["secretgen-controller/releases/download/(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)/release\\.yml"],
      "depNameTemplate": "carvel-dev/secretgen-controller",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/clusters/bare-metal/config/cert-manager/app\\.yaml/"],
      "matchStrings": ["cert-manager/releases/download/(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)/cert-manager\\.yaml"],
      "depNameTemplate": "cert-manager/cert-manager",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/clusters/bare-metal/config/external-dns/deployment\\.yaml/"],
      "matchStrings": ["image: registry\\.k8s\\.io/external-dns/external-dns:(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)"],
      "depNameTemplate": "registry.k8s.io/external-dns/external-dns",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/ansible/install-k3s\\.yaml/"],
      "matchStrings": ["image: ghcr\\.io/kube-vip/kube-vip:(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)"],
      "depNameTemplate": "ghcr.io/kube-vip/kube-vip",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/clusters/bare-metal/config/tailscale/app\\.yaml/"],
      "matchStrings": ["image: ghcr\\.io/tailscale/tailscale:(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "ghcr.io/tailscale/tailscale",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/clusters/bare-metal/config/harbor/app\\.yaml/", "/clusters/bare-metal/config/kube-vip/app\\.yaml/", "/clusters/bare-metal/config/kured/app\\.yaml/", "/clusters/bare-metal/config/longhorn/app\\.yaml/", "/clusters/bare-metal/config/monitoring/app\\.yaml/"],
      "matchStrings": ["helmChart:\\s+name: (?<depName>[^\\s]+)\\s+version: \"?(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\"?\\s+repository:\\s+url: (?<registryUrl>[^\\s]+)"],
      "datasourceTemplate": "helm"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["k3s-io/k3s"],
      "matchUpdateTypes": ["minor", "major"],
      "labels": ["k8s-upgrade"],
      "assignees": ["cdelashmutt"]
    },
    {
      "matchPackageNames": ["k3s-io/k3s"],
      "matchUpdateTypes": ["patch"],
      "enabled": false
    },
    {
      "matchPackageNames": ["ghcr.io/kube-vip/kube-vip"],
      "prBodyNotes": ["⚠️ **After merging:** re-run the Ansible playbook to push the updated DaemonSet manifest to the nodes:\n```\nansible-playbook -i ansible/inventory.ini ansible/install-k3s.yaml\n```"]
    },
    {
      "matchPackageNames": ["carvel-dev/kapp-controller", "carvel-dev/secretgen-controller"],
      "prBodyNotes": ["⚠️ **After merging:** re-run `install.sh` to apply the updated manifests to the cluster:\n```\n./install.sh\n```"]
    },
    {
      "matchPackageNames": ["longhorn"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false,
      "description": "Longhorn requires upgrading one minor version at a time — bump manually"
    },
    {
      "matchDatasources": ["helm", "github-releases", "docker"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies"],
      "assignees": ["cdelashmutt"]
    }
  ]
}
